{
  "name": "swig-cli-init",
  "version": "1.0.7",
  "author": "Mike Thompson",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/mikey-t/swig-cli-init.git"
  },
  "license": "MIT",
  "description": "Script to automate swig-cli setup",
  "keywords": [
    "swig",
    "cli",
    "swig-cli",
    "init",
    "scaffold"
  ],
  "main": "dist/src/index.js",
  "bin": {
    "swig-cli-init": "dist/src/index.js"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^10.33.0",
      "onFail": "ignore"
    },
    "runtime": {
      "name": "node",
      "version": "24.14.0"
    }
  },
  "dependencies": {
    "@mikeyt23/node-cli-utils": "^2.0.36"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@types/node": "24",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "swig-cli": "^1.0.5",
    "swig-cli-modules": "^0.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
